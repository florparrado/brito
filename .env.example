TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_CHAT_ID=123456789

# Optional but recommended for cloud deployment.
# This keeps the "already seen" memory even when the server wakes up and shuts down.
UPSTASH_REDIS_REST_URL=https://replace-me.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_me
STATE_BACKEND=upstash
STATE_KEY=barcelona-rental-monitor:state

# Optional overrides
SOURCES_FILE=config/sources.json
STATE_FILE=data/seen.json
INTERVAL_MINUTES=15
MAX_PRICE=2100
MIN_ROOMS=3
MIN_AREA=80
